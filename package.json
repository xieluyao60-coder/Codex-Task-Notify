{
  "name": "agent-task-notify",
  "displayName": "Agent Task Notify",
  "description": "Unified task completion notifications for Codex sessions across IDE, CLI, and app workflows.",
  "version": "1.10.2",
  "publisher": "ayanami-ray",
  "icon": "assets/icons/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xieluyao60-coder/Codex-Task-Notify.git"
  },
  "bugs": {
    "url": "https://github.com/xieluyao60-coder/Codex-Task-Notify/issues"
  },
  "homepage": "https://github.com/xieluyao60-coder/Codex-Task-Notify#readme",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:codexTaskNotify.toggleMonitoring",
    "onCommand:codexTaskNotify.startMonitoring",
    "onCommand:codexTaskNotify.stopMonitoring",
    "onCommand:codexTaskNotify.restartMonitoring",
    "onCommand:codexTaskNotify.continueMonitoring",
    "onCommand:codexTaskNotify.quitMonitoring",
    "onCommand:codexTaskNotify.checkBalance",
    "onCommand:codexTaskNotify.refreshBalance",
    "onCommand:codexTaskNotify.chooseWay",
    "onCommand:codexTaskNotify.setTrigger",
    "onCommand:codexTaskNotify.addSessionFile",
    "onCommand:codexTaskNotify.monitorActiveSession",
    "onCommand:codexTaskNotify.chooseSessionFile",
    "onCommand:codexTaskNotify.openConfig",
    "onCommand:codexTaskNotify.showRecentEvents",
    "onCommand:codexTaskNotify.renameSessionAlias",
    "onCommand:codexTaskNotify.clearSessionAliases",
    "onCommand:codexTaskNotify.showHotThreads",
    "onCommand:codexTaskNotify.showLastAddedSessions",
    "onCommand:codexTaskNotify.showHelp"
  ],
  "main": "./dist/extension.js",
  "files": [
    "dist/daemon.js",
    "dist/extension.js",
    "dist/vscodeDaemon.js",
    "dist/shared/**/*.js",
    "node_modules/growly/**",
    "node_modules/is-docker/**",
    "node_modules/is-wsl/**",
    "node_modules/isexe/**",
    "node_modules/node-notifier/**",
    "node_modules/semver/**",
    "node_modules/shellwords/**",
    "node_modules/uuid/**",
    "node_modules/which/**",
    "assets/**",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "codex-task-notify": "./dist/daemon.js"
  },
  "contributes": {
    "commands": [
      {
        "command": "codexTaskNotify.toggleMonitoring",
        "title": "Codex Task Notify: Toggle Monitoring"
      },
      {
        "command": "codexTaskNotify.startMonitoring",
        "title": "Codex Task Notify: Start Monitoring"
      },
      {
        "command": "codexTaskNotify.stopMonitoring",
        "title": "Codex Task Notify: Stop Monitoring"
      },
      {
        "command": "codexTaskNotify.restartMonitoring",
        "title": "Codex Task Notify: restart"
      },
      {
        "command": "codexTaskNotify.continueMonitoring",
        "title": "Codex Task Notify: continue"
      },
      {
        "command": "codexTaskNotify.quitMonitoring",
        "title": "Codex Task Notify: quit"
      },
      {
        "command": "codexTaskNotify.checkBalance",
        "title": "Codex Task Notify: check balance"
      },
      {
        "command": "codexTaskNotify.refreshBalance",
        "title": "Codex Task Notify: refresh balance"
      },
      {
        "command": "codexTaskNotify.chooseWay",
        "title": "Codex Task Notify: choose way"
      },
      {
        "command": "codexTaskNotify.setTrigger",
        "title": "Codex Task Notify: set trigger"
      },
      {
        "command": "codexTaskNotify.addSessionFile",
        "title": "Codex Task Notify: add"
      },
      {
        "command": "codexTaskNotify.monitorActiveSession",
        "title": "Codex Task Notify: Monitor Current Session"
      },
      {
        "command": "codexTaskNotify.chooseSessionFile",
        "title": "Codex Task Notify: Choose Session to Monitor"
      },
      {
        "command": "codexTaskNotify.openConfig",
        "title": "Codex Task Notify: Open Shared Config"
      },
      {
        "command": "codexTaskNotify.showRecentEvents",
        "title": "Codex Task Notify: Show Recent Events"
      },
      {
        "command": "codexTaskNotify.renameSessionAlias",
        "title": "Codex Task Notify: rename"
      },
      {
        "command": "codexTaskNotify.clearSessionAliases",
        "title": "Codex Task Notify: clear_name"
      },
      {
        "command": "codexTaskNotify.showHotThreads",
        "title": "Codex Task Notify: show"
      },
      {
        "command": "codexTaskNotify.showLastAddedSessions",
        "title": "Codex Task Notify: show_last"
      },
      {
        "command": "codexTaskNotify.showHelp",
        "title": "Codex Task Notify: help"
      }
    ],
    "configuration": {
      "title": "Codex Task Notify",
      "properties": {
        "codexTaskNotify.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Start monitoring Codex session files when the extension activates."
        },
        "codexTaskNotify.promptForSessionAlias": {
          "type": "boolean",
          "default": true,
          "description": "Prompt once for a custom Codex thread name when a new session first completes."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p .",
    "watch": "tsc -w -p .",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true });\"",
    "smoke": "npm run build && node dist/test/smoke.js",
    "start:daemon": "npm run build && node dist/daemon.js",
    "probe:latency": "npm run build && node dist/latencyProbe.js",
    "package:vsix": "npm run build && node scripts/package-vsix.js"
  },
  "dependencies": {
    "node-notifier": "^10.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "@types/node-notifier": "^8.0.5",
    "@types/vscode": "^1.96.0",
    "typescript": "^5.8.3"
  }
}
